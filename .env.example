# Copy to .env.local and adjust as needed. The real env file is never committed.

# Backend API base URL exposed to the browser for client-side calls (ky). Must
# point at the backend's versioned prefix (api.base-path, default /api/v1).
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# Backend API base URL used server-side (Server Components / Server Actions).
# Falls back to NEXT_PUBLIC_API_URL if unset. No NEXT_PUBLIC_ prefix: server only.
API_BASE_URL=http://localhost:8080/api/v1

# NEXT_PUBLIC_API_URL is also read by the login "wake the service" notice: when it
# points at a host that sleeps when idle (an .onrender.com origin) the notice is
# shown so the user can spin the backend up. Local/on-premise values hide it.

# Authentication
# The backend owns authentication entirely (Spring Security httpOnly session
# cookie). The browser holds that cookie and ky forwards it with
# `credentials: 'include'`. No auth secrets live in the frontend.
